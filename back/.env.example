# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fisuan
POSTGRES_PASSWORD=1337
POSTGRES_DB=ais_hack_1case

# Local AI service (ai/)
AI_BASE_URL=http://172.20.10.6:8001
AI_DEFAULT_MODEL=minimax-m2.5:cloud

# Whisper STT (RU baseline)
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru
WHISPER_BEAM_SIZE=3
WHISPER_TEMPERATURE=0.0
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
WHISPER_VAD_FILTER=true
WHISPER_NO_SPEECH_THRESHOLD=0.45
WHISPER_VAD_MIN_SILENCE_MS=420
WHISPER_VAD_SPEECH_PAD_MS=160
WHISPER_VAD_MIN_SPEECH_MS=120
WHISPER_HOTWORDS=джарвис,джарвиз,джарви,дамумед,прием,назначения,расписание
