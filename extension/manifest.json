{
  "manifest_version": 3,
  "name": "Damumed RPA Agent",
  "description": "Voice-driven RPA assistant for Damumed hackathon demo flows.",
  "version": "1.0.1",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Damumed RPA Agent",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "backend-bridge.js",
        "voice-commands.js",
        "damumed-dom-config.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
